# Shared model/image configuration
MODEL_NAME=unsloth/gemma-4-12B-it-qat-GGUF:UD-Q4_K_XL
RUNPOD_LLAMA_IMAGE=ghcr.io/rpatel622/runpod-llamacpp-openai:latest

# CPU load-balanced adapter sizing
FLASH_LB_CPU=cpu5c-4-8
FLASH_LB_WORKERS_MIN=1
FLASH_LB_WORKERS_MAX=5
FLASH_JOB_WAIT_TIMEOUT_SECONDS=600

# GPU queue worker sizing
FLASH_GPU_WORKERS_MIN=0
FLASH_GPU_WORKERS_MAX=3
FLASH_GPU_EXECUTION_TIMEOUT_MS=600000
LLAMA_STARTUP_TIMEOUT=1800
QUEUE_WARMUP=0
